{
  "name": "pagezero",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24.11.0",
    "bun": ">=1.3.1"
  },
  "scripts": {
    "build": "vite build",
    "check": "biome check",
    "check:fix": "biome check --write",
    "check:types": "tsc",
    "db:clean": "rm -rf ./.wrangler/state/v3/d1",
    "db:drop": "drizzle-kit drop",
    "db:export": "drizzle-kit export > ./packages/db/main/schema.sql",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB_MAIN",
    "db:push": "drizzle-kit push",
    "db:reset": "rm -rf ./packages/db/*/migrations && bun run db:generate --name=init",
    "db:studio": "drizzle-kit studio",
    "deploy:production": "CLOUDFLARE_ENV=production bun run build && wrangler deploy",
    "deploy:preview": "CLOUDFLARE_ENV=preview bun run build && wrangler deploy",
    "dev": "NODE_OPTIONS=\"--inspect\" vite dev",
    "doctor": "bun run check && bun run check:types && bun run test",
    "generate": "tsx ./packages/generate/generate.ts",
    "generate:types": "wrangler types",
    "git:clean": "git branch -l | grep -v 'main' | xargs git branch -D",
    "git:reset": "rm -rf .git && git init .",
    "preview": "NODE_ENV=development bun run build && vite preview",
    "setup": "bun install && bun run setup:env && playwright install --with-deps chromium && CI=1 bun run db:migrate",
    "setup:env": "cp .init.env .env && cp .init.env.test .env.test",
    "setup:reset": "git clean -fdxq && bun run setup",
    "setup:wrangler": "bun ./packages/config/scripts/wrangler-reset.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "bun run db:export && vitest run",
    "test:coverage": "bun run db:export && vitest run --coverage",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --ui --project=e2e",
    "test:smoke": "playwright test --project=smoke",
    "test:watch": "bun run db:export && vitest watch",
    "dev:email": "email dev -d ./apps/email/templates -p 3001"
  },
  "dependencies": {
    "@mdx-js/react": "3.1.1",
    "@polar-sh/sdk": "0.41.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/virtual-file-routes": "1.162.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "isbot": "5.1.37",
    "lucide-react": "1.8.0",
    "motion": "12.23.22",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-email": "6.1.1",
    "resend": "6.10.0",
    "tailwind-merge": "3.5.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@cloudflare/vite-plugin": "1.36.4",
    "@faker-js/faker": "10.1.0",
    "@mdx-js/rollup": "3.1.1",
    "@playwright/test": "1.59.1",
    "@react-email/ui": "6.1.1",
    "@storybook/addon-docs": "10.3.5",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "1.3.14",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "better-sqlite3": "12.8.0",
    "commander": "14.0.3",
    "drizzle-kit": "0.31.10",
    "happy-dom": "20.8.9",
    "rehype-highlight": "7.0.2",
    "remark-gfm": "4.0.1",
    "rollup-plugin-visualizer": "7.0.1",
    "storybook": "10.3.5",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wrangler": "4.90.1"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "better-sqlite3",
    "esbuild",
    "sharp",
    "workerd"
  ]
}
