{
  "name": "pagezero",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash"
  },
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "vars": {
    "CLOUDFLARE_TURNSTILE_PUBLIC_KEY": "1x00000000000000000000BB",
    "NEWSLETTER_SEGMENT_ID": ""
  },
  "d1_databases": [
    {
      "binding": "DB_MAIN",
      "database_name": "pagezero-development",
      "database_id": "<DATABASE_ID>",
      "migrations_dir": "./packages/db/main/migrations"
    }
  ],
  "env": {
    "production": {
      "vars": {
        "CLOUDFLARE_TURNSTILE_PUBLIC_KEY": "0x4AAAAAABd1vnMC0VAcAlf3",
        "NEWSLETTER_SEGMENT_ID": "f7ba881f-cec0-4c63-94ff-e3d5cc867f21"
      },
      "d1_databases": [
        {
          "binding": "DB_MAIN",
          "database_name": "pagezero-production",
          "database_id": "1e6b30f9-afaa-4368-8b76-06ed8d4fe737",
          "migrations_dir": "./packages/db/main/migrations"
        }
      ]
    },
    "preview": {
      "vars": {
        "CLOUDFLARE_TURNSTILE_PUBLIC_KEY": "0x4AAAAAABd1vnMC0VAcAlf3",
        "NEWSLETTER_SEGMENT_ID": "f7ba881f-cec0-4c63-94ff-e3d5cc867f21"
      },
      "d1_databases": [
        {
          "binding": "DB_MAIN",
          "database_name": "pagezero-preview",
          "database_id": "6eb90f35-05ce-4d9e-bd6d-a4b10ebe8c09",
          "migrations_dir": "./packages/db/main/migrations"
        }
      ]
    },
    "test": {
      "vars": {
        "CLOUDFLARE_TURNSTILE_PUBLIC_KEY": "",
        "NEWSLETTER_SEGMENT_ID": ""
      },
      "d1_databases": [
        {
          "binding": "DB_MAIN",
          "database_name": "pagezero-development",
          "database_id": "<DATABASE_ID>"
        }
      ]
    }
  }
}
